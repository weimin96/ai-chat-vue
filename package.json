{
  "name": "@weimin96/ai-chat-vue",
  "version": "0.0.1",
  "description": "A powerful Vue 3 + TailwindCSS AI Chat UI component library",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles": "./dist/style.css"
  },
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --config play/vite.config.ts",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "vue-tsc -b tsconfig.json --noEmit",
    "test": "vitest run --environment jsdom",
    "size": "size-limit",
    "prepublishOnly": "npm run build && npm run size",
    "play:build": "vite build --config play/vite.config.ts",
    "play:preview": "vite preview --config play/vite.config.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "mermaid": "^11.14.0",
    "shiki": "^4.0.2",
    "vue": "^3.5.33"
  },
  "peerDependenciesMeta": {
    "mermaid": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  },
  "dependencies": {
    "dompurify": "^3.4.2",
    "marked": "^18.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@size-limit/file": "^12.1.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "jsdom": "^27.3.0",
    "mermaid": "^11.14.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "shiki": "^4.0.2",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.8"
  },
  "keywords": [
    "vue",
    "ai",
    "chat",
    "tailwindcss",
    "llm",
    "openai",
    "streaming"
  ],
  "license": "MIT",
  "size-limit": [
    {
      "path": "dist/index.esm.js",
      "limit": "120 KB"
    },
    {
      "path": "dist/style.css",
      "limit": "80 KB"
    }
  ]
}
